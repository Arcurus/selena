# Environment and secrets (NEVER commit these)
.env
.env.*
*.env

# Data files (project operational data - SAFE to commit for backup)
# Note: Only .env files contain sensitive data, other data can be in git
data/backups/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Memory files (personal notes - keep private)
memory/daily/*.md
